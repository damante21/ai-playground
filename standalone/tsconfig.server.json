{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "../dist/server",
    "baseUrl": "..",
    "paths": {
      "*": ["node_modules/*"]
    }
  },
  "include": [
    "./**/*.ts",
    "../server/**/*.ts"
  ],
  "exclude": [
    "../node_modules",
    "../dist"
  ]
}
